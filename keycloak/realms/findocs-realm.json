{
  "realm": "findocs",
  "enabled": true,
  "displayName": "findocs",
  "registrationAllowed": false,
  "resetPasswordAllowed": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "sslRequired": "external",
  "loginTheme": "nl-design-system",
  "accountTheme": "nl-design-system",
  "clients": [
    {
      "clientId": "findocs-bff",
      "name": "findocs BFF",
      "description": "Backend-for-Frontend confidential client for the findocs app.",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "dev-secret-change-me",
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "fullScopeAllowed": true,
      "redirectUris": [
        "http://localhost:8080/api/auth/callback",
        "http://localhost:5173/api/auth/callback",
        "__PUBLIC_URL__/api/auth/callback"
      ],
      "webOrigins": [
        "http://localhost:8080",
        "http://localhost:5173",
        "__PUBLIC_URL__"
      ],
      "attributes": {
        "post.logout.redirect.uris": "http://localhost:8080/*##http://localhost:5173/*##__PUBLIC_URL__/*",
        "pkce.code.challenge.method": "S256"
      }
    }
  ],
  "users": [
    {
      "username": "demo",
      "enabled": true,
      "emailVerified": true,
      "email": "demo@findocs.local",
      "firstName": "Demo",
      "lastName": "Gebruiker",
      "credentials": [
        {
          "type": "password",
          "value": "demo",
          "temporary": false
        }
      ],
      "realmRoles": ["gebruiker"]
    }
  ],
  "roles": {
    "realm": [
      {
        "name": "gebruiker",
        "description": "Standaard toegang tot de findocs invulhulp."
      }
    ]
  }
}
